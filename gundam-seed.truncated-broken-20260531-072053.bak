                        <i class="fa-solid fa-heart"></i>
                        <span>MY REEL</span>
                    </button>

                    <!-- Filters grouped -->
                    <div class="flex items-center gap-1.5 overflow-x-auto pb-1 md:pb-0 -mx-1 px-1 md:mx-0 md:px-0 flex-1 md:flex-none" id="gundam-filters-wrapper">
                        <div class="flex flex-nowrap md:flex-wrap gap-1.5" id="gundam-filters">
                            <button data-filter="all" aria-pressed="true" class="active filter-chip px-3.5 py-1.5 text-[10px] tracking-widest border border-[#C5A26E] bg-[#C5A26E] text-black rounded-2xl">ALL</button>
