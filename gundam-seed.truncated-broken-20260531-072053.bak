                            <button data-filter="终端" class="filter-chip px-3.5 py-1.5 text-[10px] tracking-widest border border-white/15 hover:border-white/40 rounded-2xl">TERMINAL</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
                <div class="flex flex-nowrap md:flex-wrap gap-2" id="gundam-filters">
                    <button data-filter="all" aria-pressed="true" aria-label="显示全部高达" class="active filter-chip px-4 py-2 text-xs tracking-widest border border-[#C5A26E] bg-[#C5A26E] text-black rounded-2xl">ALL</button>
                    <button data-filter="ZAFT" aria-pressed="false" aria-label="筛选 ZAFT 势力高达" class="filter-chip px-4 py-2 text-xs tracking-widest border border-white/15 hover:border-white/40 rounded-2xl">ZAFT</button>
                    <button data-filter="地球联合" aria-pressed="false" aria-label="筛选 地球联合 势力高达" class="filter-chip px-4 py-2 text-xs tracking-widest border border-white/15 hover:border-white/40 rounded-2xl">EARTH ALLIANCE</button>
                    <button data-filter="奥布" aria-pressed="false" aria-label="筛选 奥布 势力高达" class="filter-chip px-4 py-2 text-xs tracking-widest border border-white/15 hover:border-white/40 rounded-2xl">ORB</button>
                    <button data-filter="终端" aria-pressed="false" aria-label="筛选 终端 势力高达" class="filter-chip px-4 py-2 text-xs tracking-widest border border-white/15 hover:border-white/40 rounded-2xl">TERMINAL</button>
                    <button data-filter="Extended" aria-pressed="false" aria-label="筛选 Extended 势力高达" class="filter-chip px-4 py-2 text-xs tracking-widest border border-white/15 hover:border-white/40 rounded-2xl">EXTENDED</button>
